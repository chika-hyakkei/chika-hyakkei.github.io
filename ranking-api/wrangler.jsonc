{
  "name": "chika-hyakkei-ranking",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-19",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "chika-hyakkei-ranking",
      "database_id": "REPLACE_WITH_D1_DATABASE_ID",
      "migrations_dir": "migrations"
    }
  ],
  "vars": {
    "ALLOWED_ORIGIN": "https://chika-hyakkei.github.io"
  }
}
